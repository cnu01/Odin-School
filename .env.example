# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=odin_school_db

# FastAPI Configuration
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# CORS Settings (Add your frontend URLs)
CORS_ORIGINS=http://localhost:8000,http://localhost:8001

# Amazon Bedrock Configuration for TrustDesk
# AWS Credentials for Amazon Bedrock Claude-v2 integration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# AWS Vector Database Configuration
# Choose one of the following vector database options:

# Option 1: Amazon Bedrock Knowledge Bases (Easiest - Recommended for quick start)
BEDROCK_KNOWLEDGE_BASE_ID=your_knowledge_base_id_here
BEDROCK_DATA_SOURCE_ID=your_data_source_id_here
S3_BUCKET_NAME=your_s3_bucket_for_documents

# Option 2: Amazon OpenSearch Serverless (Production - Recommended for scale)
OPENSEARCH_ENDPOINT=your_opensearch_endpoint_here
OPENSEARCH_INDEX_NAME=trustdesk_knowledge

# Option 3: Amazon RDS PostgreSQL with pgvector (Cost-effective)
RDS_ENDPOINT=your_rds_endpoint_here
RDS_DATABASE=trustdesk_vectors
RDS_USERNAME=your_rds_username
RDS_PASSWORD=your_rds_password

# Vector Database Selection (choose one: bedrock_kb, opensearch, rds_pgvector)
VECTOR_DB_TYPE=bedrock_kb

# Note: Make sure your AWS account has access to Amazon Bedrock
# and the Claude-v2 model (anthropic.claude-v2) is enabled in your region

# Legacy AI Configuration (no longer used by TrustDesk)
# AI_API_KEY=your_openai_api_key_here